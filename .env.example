# ============================================================
# LocalAI TV - Environment Variables Example
# Copy this to .env and fill in your values
# ============================================================

# ============================================================
# Server
# ============================================================
PORT=8000
API_BASE_URL=https://srv1264596.hstgr.cloud

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_HEADLINE_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# ============================================================
# Sarvam TTS
# ============================================================
SARVAM_API_KEY=sk-your-sarvam-key-here

# ============================================================
# Gupshup WhatsApp
# ============================================================
GUPSHUP_API_KEY=your-gupshup-api-key
GUPSHUP_APP_NAME=your-app-name
GUPSHUP_SOURCE_NUMBER=918523847888

# ============================================================
# Database (PostgreSQL / CloudSQL)
# ============================================================
DB_TYPE=postgres
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname?sslmode=require&connect_timeout=5

# ============================================================
# AWS S3 (Main Bucket)
# ============================================================
USE_S3=true
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-2
S3_BUCKET_NAME=your-bucket-name
S3_STATIC_PREFIX=static-assets

# ============================================================
# AWS S3 (External Bucket - whoiswho, ads, etc.)
# ============================================================
AWS_ACCESS_KEY_ID_M=your-external-access-key
AWS_SECRET_ACCESS_KEY_M=your-external-secret-key
AWS_REGION_M=ap-south-2
S3_BUCKET_NAME_M=your-external-bucket
S3_BULLETIN_PREFIX=whoiswho/outputs

# ============================================================
# LocalAI TV APIs
# ============================================================
LOCALAITV_API_URL=https://localaitv.com
LOCALAITV_API_TOKEN=your-api-token
LOCALAITV_CATEGORY_ID=1
BULLETIN_API_TOKEN=your-bulletin-token

# ============================================================
# YouTube Streaming
# ============================================================
YOUTUBE_STREAMING_ENABLED=true
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2
YT_STREAM_KEY=your-stream-key
YT_STREAM_KEY_KURNOOL=your-kurnool-key
YT_STREAM_KEY_KARIMNAGAR=your-karimnagar-key
YT_DATA_API_KEY=your-data-api-key
STREAM_COUNT=7
STREAM_MODE=copy
WATCH_DIR_BASE=/root/localaitv1/outputs/bulletins

# ============================================================
# Feature Flags
# ============================================================
TICKER_ENABLED=true
S3_INJECT_ENABLED=true
FIVE_MIN_INJECT_ENABLED=true
BGM_ENABLED=true
BGM_VOLUME=0.25
BGM_FADE_SECONDS=2.5
S3_INJECT_DURATION=60

# ============================================================
# Background Workers
# ============================================================
ENABLE_PLANNER=true
ENABLE_REPORT_POLLER=true
ENABLE_RETRY=true
ENABLE_CLEANUP=true