# ============================================================
# SSM Parameter Store paths for localaitv staging (Phase 1)
# ============================================================
# Path convention:  /localaitv/stg/<ENV_VAR_NAME>
# Type:             SecureString (for all secret/credential params)
#
# This file lists PATHS ONLY. It contains NO VALUES.
# Values are loaded from a LOCAL, untracked .env by load-secrets.sh.
#
# Derived from .env.example variable names. Low-sensitivity config
# values (PORT, model names, feature flags, etc.) are intentionally
# NOT stored as SecureString here — they belong in the task definition
# / image defaults, not Parameter Store. Only secrets + credential URLs
# are listed below.
# ============================================================

# --- Auth / API keys (HIGH sensitivity) -> SecureString ---
/localaitv/stg/OPENAI_API_KEY
/localaitv/stg/SARVAM_API_KEY
/localaitv/stg/GUPSHUP_API_KEY
/localaitv/stg/LOCALAITV_API_TOKEN
/localaitv/stg/BULLETIN_API_TOKEN
/localaitv/stg/YT_DATA_API_KEY
/localaitv/stg/YT_STREAM_KEY
/localaitv/stg/YT_STREAM_KEY_KURNOOL
/localaitv/stg/YT_STREAM_KEY_KARIMNAGAR

# --- AWS credentials (HIGH sensitivity) -> SecureString ---
# NOTE: Prefer IAM task roles over static keys in AWS. These params exist
# only as a fallback for parity with the existing .env-based deployment.
/localaitv/stg/AWS_ACCESS_KEY_ID
/localaitv/stg/AWS_SECRET_ACCESS_KEY
/localaitv/stg/AWS_ACCESS_KEY_ID_M
/localaitv/stg/AWS_SECRET_ACCESS_KEY_M

# --- Credentials / URLs (MEDIUM sensitivity) -> SecureString ---
/localaitv/stg/DATABASE_URL
